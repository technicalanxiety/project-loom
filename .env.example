# PostgreSQL
DATABASE_URL=postgres://loom:loom@postgres:5432/loom
DATABASE_URL_ONLINE=postgres://loom:loom@postgres:5432/loom
DATABASE_URL_OFFLINE=postgres://loom:loom@postgres:5432/loom

# Connection pool sizes
ONLINE_POOL_MAX=10
OFFLINE_POOL_MAX=5
ONLINE_POOL_MIN=2
OFFLINE_POOL_MIN=1

# Pool tuning
POOL_ACQUIRE_TIMEOUT_SECS=5
POOL_IDLE_TIMEOUT_SECS=300
STATEMENT_TIMEOUT_SECS=30
HOT_TIER_CACHE_TTL_SECS=60

# Test Database (docker-compose.test.yml — port 5433, ephemeral)
DATABASE_URL_TEST=postgres://loom_test:loom_test@localhost:5433/loom_test

# Ollama (Primary LLM)
OLLAMA_URL=http://ollama:11434
EXTRACTION_MODEL=gemma4:26b
CLASSIFICATION_MODEL=gemma4:e4b
EMBEDDING_MODEL=nomic-embed-text

# Azure OpenAI (Fallback)
AZURE_OPENAI_URL=
AZURE_OPENAI_KEY=

# Authentication
LOOM_BEARER_TOKEN=changeme

# Server
LOOM_HOST=0.0.0.0
LOOM_PORT=8080

# Logging
RUST_LOG=loom_engine=info,tower_http=debug
