# PostgreSQL
DATABASE_URL=postgres://loom:loom@postgres:5432/loom
DATABASE_URL_ONLINE=postgres://loom:loom@postgres:5432/loom
DATABASE_URL_OFFLINE=postgres://loom:loom@postgres:5432/loom

# Connection pool sizes
ONLINE_POOL_MAX=10
OFFLINE_POOL_MAX=5
ONLINE_POOL_MIN=2
OFFLINE_POOL_MIN=1

# Pool tuning
POOL_ACQUIRE_TIMEOUT_SECS=5
POOL_IDLE_TIMEOUT_SECS=300
STATEMENT_TIMEOUT_SECS=30
HOT_TIER_CACHE_TTL_SECS=60

# ── Episode processing retry/backoff ─────────────────────────
# Controls the offline worker's behavior when an episode fails
# extraction (e.g. content that exceeds the embedding model's
# context window). See docs/adr/007-episode-processing-retry-backoff.md.
#
# After EPISODE_MAX_ATTEMPTS, a failing episode transitions to
# processing_status='failed' and stops retrying — the dashboard
# surfaces it for operator triage via /dashboard/api/episodes/failed.
# Actual retry delay for attempt N is EPISODE_BACKOFF_BASE_SECS * 2^N,
# so with the defaults below: 30s, 60s, 120s, 240s, 480s.
EPISODE_MAX_ATTEMPTS=5
EPISODE_BACKOFF_BASE_SECS=30

# Test Database (docker-compose.test.yml — port 5433, ephemeral)
DATABASE_URL_TEST=postgres://loom_test:loom_test@localhost:5433/loom_test

# ── Ollama (Primary LLM) ─────────────────────────────────────
# Default is native Ollama on the Docker host (brew install ollama on
# macOS). Apple Silicon: required — Docker Ollama cannot use Metal and
# is 3-5x more memory-hungry. Linux + CUDA: use the dockered profile
# instead by setting OLLAMA_URL=http://ollama:11434 and running
# `docker compose --profile with-docker-ollama up -d`.
OLLAMA_URL=http://host.docker.internal:11434

# Models. On a 16 GB Mac, set EXTRACTION_MODEL=gemma4:e4b so both the
# classifier and the extractor share one compact model — gemma4:26b
# extraction is only viable with >=24 GB. Swap back to gemma4:26b once
# you're on beefier hardware or are comfortable closing heavy apps
# during extraction.
EXTRACTION_MODEL=gemma4:e4b
CLASSIFICATION_MODEL=gemma4:e4b
EMBEDDING_MODEL=nomic-embed-text

# Azure OpenAI (Fallback)
AZURE_OPENAI_URL=
AZURE_OPENAI_KEY=

# Authentication
LOOM_BEARER_TOKEN=changeme

# Server
LOOM_HOST=0.0.0.0
LOOM_PORT=8080

# Logging
RUST_LOG=loom_engine=info,tower_http=debug
