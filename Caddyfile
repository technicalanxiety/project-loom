# Caddyfile — Caddy reverse proxy for Project Loom
#
# By default Caddy serves only localhost (self-signed cert via its local CA).
# To also serve on a LAN IP (e.g. a headless Linux node), set LOOM_LAN_HOST
# in .env to the host's LAN address (e.g. 192.168.1.50). Caddy will issue
# an internal cert for that address automatically.
#
#   LOOM_LAN_HOST=192.168.1.50   # set in .env; leave unset for localhost-only

{
	# Global options
}

localhost, {$LOOM_LAN_HOST:localhost} {
	tls internal
	# ── MCP endpoints → loom-engine ──────────────────────────
	# External MCP clients (Claude Code, Claude Desktop, ChatGPT Desktop,
	# GitHub Copilot, M365 Copilot, etc.) must supply their own
	# `Authorization: Bearer <token>` header. Caddy does not inject one
	# here.
	#
	# `/mcp` (no trailing slash) is the JSON-RPC 2.0 dispatcher — this is
	# what MCP clients hit. `/mcp/*` covers the per-tool REST endpoints
	# (/mcp/loom_learn, /mcp/loom_think, /mcp/loom_recall). Caddy's `/mcp/*`
	# matcher does NOT match the bare `/mcp` path, so a named matcher
	# covers both in one route.
	@mcp path /mcp /mcp/*
	handle @mcp {
		reverse_proxy loom-engine:8080
	}

	# ── REST API → loom-engine ───────────────────────────────
	# Same contract as /mcp/*. External clients bring their own token.
	handle /api/* {
		reverse_proxy loom-engine:8080
	}

	# ── Dashboard API → loom-engine ──────────────────────────
	# The SPA runs in a browser and cannot carry a token of its own.
	# Caddy injects the shared bearer token on requests originating from
	# the dashboard SPA so the user does not have to manage a token in
	# browser storage. This trades CSRF exposure on /dashboard/api/*
	# endpoints for simplicity — acceptable for personal-infrastructure
	# deployment where Caddy is bound to localhost or a trusted network.
	# If you deploy to a hostile network, add a login flow instead.
	handle /dashboard/api/* {
		reverse_proxy loom-engine:8080 {
			header_up Authorization "Bearer {env.LOOM_BEARER_TOKEN}"
		}
	}

	# ── Dashboard static files (SPA fallback) ────────────────
	handle {
		root * /srv/dashboard
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
	}
}
